{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Python Environment",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\scripts\\setup_env.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Freeze Requirements",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        ".\\scripts\\freeze_requirements.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe",
      "args": [
        "-m",
        "pytest"
      ],
      "problemMatcher": []
    }
  ]
}

